{
  "manifest_version": 3,
  "name": "YouTube Language Filter",
  "version": "1.0.0",
  "description": "Find YouTube videos in a selected language, minimize distractions on YouTube. Optionally also filter by country.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.googleapis.com/",
    "https://translate.googleapis.com/"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Language Filter — Settings"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["early.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
